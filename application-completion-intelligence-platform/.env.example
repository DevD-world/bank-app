HOST=0.0.0.0
PORT=8000
COMPLETION_IQ_DATA_DIR=/var/data
COMPLETION_IQ_DB_PATH=/var/data/completion_iq.sqlite3
COMPLETION_IQ_UPLOAD_DIR=/var/data/uploads
COMPLETION_IQ_PRODUCTION=1
COMPLETION_IQ_ALLOWED_ORIGIN=https://your-production-domain.example
COMPLETION_IQ_MAX_PAYLOAD_BYTES=5242880
COMPLETION_IQ_OCR_WORKERS=8
COMPLETION_IQ_OCR_TIMEOUT_SECONDS=30
COMPLETION_IQ_DATABASE_KIND=sqlite
COMPLETION_IQ_OCR_PROVIDER=

# Required for production/staging staff APIs.
# Generate a long random value and enter it in staff sessions, never in source control.
COMPLETION_IQ_API_KEY=replace-with-long-random-secret
